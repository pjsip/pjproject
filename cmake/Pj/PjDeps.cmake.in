# PjDeps.cmake - Generated by pjproject CMake build
#
# Recreates Pj::Dep::* targets that map to either bundled (exported in
# PjTargets) or system (via find_dependency) third-party libraries.

include(CMakeFindDependencyMacro)

# Temporarily add our Find modules for system dependency discovery
set(_pj_saved_module_path "${CMAKE_MODULE_PATH}")
list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")

# Bundled dependencies: real targets are exported as Pj::<subdir> in PjTargets.
# Create INTERFACE IMPORTED targets that forward to them.
set(_pj_bundled_deps "@PJ_BUNDLED_DEPS_STR@")

set(_pj_bundled_target_G7221      "Pj::g7221")
set(_pj_bundled_target_GSM        "Pj::gsm")
set(_pj_bundled_target_iLBC       "Pj::ilbc")
set(_pj_bundled_target_Resample   "Pj::resample")
set(_pj_bundled_target_Speex      "Pj::speex")
set(_pj_bundled_target_SRTP       "Pj::srtp")
set(_pj_bundled_target_YUV        "Pj::yuv")
set(_pj_bundled_target_WebRTC     "Pj::webrtc")
set(_pj_bundled_target_WebRTC_AEC3 "Pj::webrtc_aec3")

foreach(_dep IN LISTS _pj_bundled_deps)
  if(NOT TARGET Pj::Dep::${_dep} AND DEFINED _pj_bundled_target_${_dep})
    if(TARGET ${_pj_bundled_target_${_dep}})
      add_library(Pj::Dep::${_dep} INTERFACE IMPORTED)
      set_target_properties(Pj::Dep::${_dep} PROPERTIES
        INTERFACE_LINK_LIBRARIES "${_pj_bundled_target_${_dep}}"
      )
    else()
      message(WARNING "pjproject: bundled target ${_pj_bundled_target_${_dep}} "
        "not found for Pj::Dep::${_dep}")
    endif()
  endif()
endforeach()

# System dependencies: locate via find_dependency, then create forwarding
# targets.
set(_pj_system_deps "@PJ_SYSTEM_DEPS_STR@")

set(_pj_system_package_G7221    "G7221")
set(_pj_system_package_GSM      "GSM")
set(_pj_system_package_Resample "Resample")
set(_pj_system_package_Speex    "Speex")
set(_pj_system_package_SRTP     "SRTP")
set(_pj_system_package_YUV      "YUV")

foreach(_dep IN LISTS _pj_system_deps)
  if(NOT TARGET Pj::Dep::${_dep} AND DEFINED _pj_system_package_${_dep})
    find_dependency(${_pj_system_package_${_dep}})
    set(_sys_target "${_pj_system_package_${_dep}}::${_pj_system_package_${_dep}}")
    if(TARGET ${_sys_target})
      add_library(Pj::Dep::${_dep} INTERFACE IMPORTED)
      set_target_properties(Pj::Dep::${_dep} PROPERTIES
        INTERFACE_LINK_LIBRARIES "${_sys_target}"
      )
    else()
      message(WARNING "pjproject: system target ${_sys_target} "
        "not found for Pj::Dep::${_dep}")
    endif()
    unset(_sys_target)
  endif()
endforeach()

# Restore module path and cleanup
set(CMAKE_MODULE_PATH "${_pj_saved_module_path}")
unset(_pj_saved_module_path)
unset(_pj_bundled_deps)
unset(_pj_system_deps)
